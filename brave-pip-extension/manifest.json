{
  "manifest_version": 3,
  "name": "Opera GX Style PiP",
  "version": "1.0",
  "description": "Botão de Picture-in-Picture flutuante sobre os vídeos, estilo Opera GX.",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png"
  }
}